[
  {
    "id": 1,
    "name": "桂枝汤",
    "source": "《伤寒论》",
    "originalText": "太阳中风，阳浮而阴弱，阳浮者热自发，阴弱者汗自出，啬啬恶寒，淅淅恶风，翕翕发热，鼻鸣干呕者，桂枝汤主之。",
    "composition": [
      {
        "name": "桂枝",
        "dosage": "9g"
      },
      {
        "name": "芍药",
        "dosage": "9g"
      },
      {
        "name": "甘草",
        "dosage": "6g"
      },
      {
        "name": "生姜",
        "dosage": "9g"
      },
      {
        "name": "大枣",
        "dosage": "3枚"
      }
    ],
    "indications": "外感风寒表虚证。症见头痛发热，汗出恶风，鼻鸣干呕，苔白不渴，脉浮缓或浮弱。",
    "modernUse": "普通感冒、流行性感冒属风寒表虚者；过敏性鼻炎；荨麻疹等皮肤过敏性疾病"
  },
  {
    "id": 2,
    "name": "麻黄汤",
    "source": "《伤寒论》",
    "originalText": "太阳病，头痛发热，身疼腰痛，骨节疼痛，恶风无汗而喘者，麻黄汤主之。",
    "composition": [
